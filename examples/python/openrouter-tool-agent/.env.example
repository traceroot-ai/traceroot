# TraceRoot
TRACEROOT_API_KEY=your_traceroot_api_key_here
# Override to send traces to a local dev server instead of app.traceroot.ai
# TRACEROOT_HOST_URL=http://localhost:8000

# OpenRouter — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: shows up in your OpenRouter dashboard for app attribution
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_X_TITLE=My TraceRoot Demo
