{
  "$schema": "https://mintlify.com/docs.json",
  "name": "TraceRoot",
  "theme": "mint",
  "colors": {
    "primary": "#0f172a",
    "light": "#FFFFFF",
    "dark": "#000000"
  },
  "rounded": "default",
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "layout": {
    "wide": true
  },
  "favicon": "/logo/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://traceroot.ai",
    "size": 36
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "search": {
    "ai": true
  },
  "navbar": {
    "links": [
      {
        "label": "Examples",
        "href": "https://github.com/traceroot-ai/traceroot/tree/main/examples"
      },
      {
        "label": "TraceRoot Cloud",
        "href": "https://app.traceroot.ai"
      },
      {
        "label": "Discord",
        "icon": "discord",
        "href": "https://discord.gg/TM2m3CtKuC"
      }
    ],
    "primary": {
      "type": "github",
      "label": "Github",
      "href": "https://github.com/traceroot-ai/traceroot"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "getting-started/introduction",
              "getting-started/quickstart",
              "developer/self-hosting"
            ]
          },
          {
            "group": "Tracing",
            "pages": [
              "tracing/introduction",
              "tracing/get-started",
              {
                "group": "SDKs",
                "pages": [
                  "tracing/python-sdk",
                  "tracing/typescript-sdk"
                ]
              },
              {
                "group": "Features",
                "pages": [
                  "tracing/overview",
                  "tracing/users",
                  "tracing/sessions",
                  "tracing/tags",
                  "tracing/metadata",
                  "tracing/cost-tracking",
                  "tracing/git-context",
                  "tracing/timeline",
                  "tracing/live-streaming"
                ]
              }
            ]
          },
          {
            "group": "AI Agents",
            "pages": [
              "ai-agent/overview",
              {
                "group": "Get Started",
                "pages": [
                  "ai-agent/github-integration",
                  "ai-agent/byok"
                ]
              },
              {
                "group": "Features",
                "pages": [
                  "ai-agent/trace-analysis",
                  "ai-agent/root-cause-analysis",
                  "ai-agent/pr-creation"
                ]
              }
            ]
          },
          {
            "group": "Detectors",
            "pages": [
              "detectors/introduction",
              "detectors/get-started",
              "detectors/alerts"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/get-started"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "terminal",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/v1/public/traces",
              "GET /api/v1/public/traces",
              "GET /api/v1/public/traces/{trace_id}",
              "GET /api/v1/public/traces/{trace_id}/export",
              "GET /api/v1/public/whoami"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "icon": "puzzle-piece",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "integrations/overview"
            ]
          },
          {
            "group": "Native",
            "pages": [
              "tracing/python-sdk",
              "tracing/typescript-sdk"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "integrations/agno",
              "integrations/autogen",
              "integrations/claude-agent-sdk",
              "integrations/crewai",
              "integrations/dspy",
              "integrations/google-adk",
              "integrations/langchain",
              "integrations/langchain-deepagents",
              "integrations/llamaindex",
              "integrations/mastra",
              "integrations/openai-agents-sdk",
              "integrations/pydantic-ai",
              "integrations/vercel-ai"
            ]
          },
          {
            "group": "Model Providers",
            "pages": [
              "integrations/anthropic",
              "integrations/gemini",
              "integrations/mistral",
              "integrations/openai",
              "integrations/openrouter"
            ]
          },
          {
            "group": "Internal Model Providers",
            "pages": [
              "integrations/internal-models"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/traceroot-ai",
