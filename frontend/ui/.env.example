# Traceroot Environment Variables
#
# Copy this file to .env and update values as needed.
# Values marked with CHANGEME should be changed in production.

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=public" # CHANGEME


# NextAuth
NEXTAUTH_URL="http://localhost:3000" # CHANGEME
NEXTAUTH_SECRET="your-nextauth-secret" # CHANGEME

# Google OAuth
AUTH_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com" # CHANGEME
AUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret" # CHANGEME

# Public API endpoint used by the frontend
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1" # CHANGEME

# Internal API secret (shared with Python backend for service-to-service auth)
INTERNAL_API_SECRET="dev-internal-secret" # CHANGEME in production

# Email (optional - for workspace invitations)
# TRACEROOT_SMTP_URL="smtp://user:pass@host:port"
# TRACEROOT_SMTP_MAIL_FROM="noreply@yourdomain.com"

# Stripe Billing
# Note: STRIPE_PRICE_ID_* variables are configured in packages/core/.env
STRIPE_WEBHOOK_SIGNING_SECRET="whsec_xxx" # CHANGEME - from Stripe CLI or Dashboard > Webhooks
