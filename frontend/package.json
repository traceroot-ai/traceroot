{
  "name": "traceroot-frontend",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "protobufjs": ">=7.5.5",
      "defu": ">=6.1.5",
      "fast-xml-parser": ">=5.7.0",
      "basic-ftp": ">=5.3.0",
      "axios": ">=1.15.0",
      "follow-redirects": ">=1.16.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.54.0"
  }
}
